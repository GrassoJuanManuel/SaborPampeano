</table>

<h3>AUTOCLAVE</h3>
<table>
<tr><th>Frecuencia</th><th>Tarea</th><th>Responsable</th></tr>
<tr><td>Diario</td><td>Verificar nivel de agua, drenaje libre</td><td>Operador</td></tr>
<tr><td>Diario</td><td>Inspección visual empaquetadura de puerta</td><td>Operador</td></tr>
<tr><td>Semanal</td><td>Verificar válvula de seguridad (presión)</td><td>Técnico</td></tr>
<tr><td>Semanal</td><td>Purgar sistema de vapor</td><td>Técnico</td></tr>
<tr><td>Mensual</td><td>Verificar manómetro y termómetro</td><td>Técnico</td></tr>
