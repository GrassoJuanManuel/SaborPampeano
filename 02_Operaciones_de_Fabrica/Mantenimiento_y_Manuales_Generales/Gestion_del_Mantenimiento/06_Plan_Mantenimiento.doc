<h2>2. Plan Preventivo por Equipo</h2>

<h3>ROBOQBO QBO 25-4</h3>
<table>
<tr><th>Frecuencia</th><th>Tarea</th><th>Responsable</th></tr>
<tr><td>Diario</td><td>Limpieza CIP o manual post-uso (ver POES-004)</td><td>Operador</td></tr>
<tr><td>Diario</td><td>Verificar estado de sellos de tapa</td><td>Operador</td></tr>
<tr><td>Semanal</td><td>Inspección visual cuchillas (desgaste, filo)</td><td>Operador</td></tr>
<tr><td>Semanal</td><td>Verificar conexiones eléctricas y mangueras</td><td>Técnico</td></tr>
<tr><td>Mensual</td><td>Lubricación según manual del fabricante</td><td>Técnico</td></tr>
<tr><td>Mensual</td><td>Verificar sistema de vacío (-990mbar)</td><td>Técnico</td></tr>
<tr><td>Trimestral</td><td>Calibración sensor de temperatura</td><td>Técnico</td></tr>
<tr><td>Anual</td><td>Servicio técnico completo (proveedor)</td><td>Proveedor</td></tr>
</table>

<h3>LSL LLENADORA (Cadec)</h3>
<table>
<tr><th>Frecuencia</th><th>Tarea</th><th>Responsable</th></tr>
<tr><td>Diario</td><td>Limpieza de tolva (60L) y boquillas</td><td>Operador</td></tr>
<tr><td>Diario</td><td>Verificar que no haya fugas de producto</td><td>Operador</td></tr>
<tr><td>Semanal</td><td>Inspección mangueras neumáticas</td><td>Técnico</td></tr>
<tr><td>Semanal</td><td>Verificar precisión de dosificación (pesar 5 frascos)</td><td>Operador + QC</td></tr>
<tr><td>Mensual</td><td>Lubricación partes móviles</td><td>Técnico</td></tr>
<tr><td>Mensual</td><td>Verificar presión de aire comprimido</td><td>Técnico</td></tr>
<tr><td>Trimestral</td><td>Calibración volumétrica</td><td>Técnico</td></tr>
<tr><td>Anual</td><td>Servicio completo Cadec</td><td>Proveedor</td></tr>
</table>

