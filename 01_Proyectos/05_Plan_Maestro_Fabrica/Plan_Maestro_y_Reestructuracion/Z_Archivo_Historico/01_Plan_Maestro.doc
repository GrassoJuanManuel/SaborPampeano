<tr><td>Horno pizzero</td><td>Tartas/tortillas</td></tr>
<tr><td>4x Anafes</td><td>Dorar cebollas/verduras para rellenos de tartas</td></tr>
<tr><td>Freidora</td><td>Freír papas para tortillas de papa</td></tr>
<tr><td>2x Sous vide</td><td>Viandas (inactivos)</td></tr>
<tr><td>Amasadora</td><td>Masa de tartas</td></tr>
<tr><td>Sobadora/Laminadora</td><td>Aplana masa (sobre Mesada 225x65)</td></tr>
<tr><td>Enfriadora rápida</td><td>Junto al Rational y Turbovar — enfriamiento tartas/tortillas</td></tr>
<tr><td>2x Turbovar</td><td>Sellado vacío tartas/tortillas</td></tr>
<tr><td>Bachas</td><td>Lavado de utensilios</td></tr>
